# Copy to .env.production and fill in. Used by scripts/deploy_cloudrun.ps1.
# .env.production is gitignored — never commit real credentials.

# Neon Postgres connection string (Dashboard -> Connect -> psql string)
DATABASE_URL=postgresql://USER:PASSWORD@YOUR-PROJECT.neon.tech/neondb?sslmode=require

# Gmail SMTP for verification emails. SMTP_PASSWORD is a Gmail App Password
# (https://myaccount.google.com/apppasswords), NOT your real password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=you@gmail.com
SMTP_PASSWORD=abcdefghijklmnop
SMTP_FROM=you@gmail.com
