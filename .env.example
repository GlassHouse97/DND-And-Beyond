APP_ENV=development

# Production database (e.g. a Neon Postgres connection string). When set, the
# app runs on Postgres; when blank, it uses a local SQLite file — no setup.
DATABASE_URL=

# Runtime data defaults to ./.workspace_data/runtime/data. This directory is
# ignored by Git, Docker, and the Reflex development file watcher.
# Do not point this at the project folder while running Reflex dev mode; SQLite
# WAL/SHM writes inside the watched repo cause browser refresh loops.
DND_DATA_DIR=

SRD_API_BASE=https://www.dnd5eapi.co

# Optional production email settings. If these are blank, verification emails
# are written next to the SQLite DB for local testing.
APP_BASE_URL=http://localhost:3000
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@dnd-and-beyond.local
